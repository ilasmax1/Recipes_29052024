# Telegram Bot Token
# Get it from @BotFather in Telegram: /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# DeepSeek API Key (приоритет — дешевле)
# Get it from https://platform.deepseek.com/api_keys
OPENAI_API_KEY_depseak=your_deepseek_api_key_here

# OpenAI API Key (резерв, также нужен для Whisper транскрипции голоса)
# Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY_openAi=your_openai_api_key_here
